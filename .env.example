# ─────────────────────────────────────────────────────────────────────────────
# AgriSentinel environment template.
#
#   cp .env.example .env   then fill in ANTHROPIC_API_KEY.
#
# The committed .env.example carries only non-secret defaults that match the
# docker-compose service names. Your real .env is gitignored — never commit it.
# NOTHING in this repository hardcodes a machine path, host, or credential:
# every value below is read from the environment at runtime.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic (the only credential a grader must supply) ──
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Default to the most capable model. For large dossier batches you may switch to
# claude-sonnet-4-6 (cheaper) or claude-haiku-4-5 (cheapest) without code changes.
ANTHROPIC_MODEL=claude-opus-4-8

# ── PostGIS (+ pgvector) ──
# Inside docker compose the host is the service name `postgis`.
# Running scripts from your host instead? Use localhost:5432.
POSTGRES_USER=agrisentinel
POSTGRES_PASSWORD=agrisentinel
POSTGRES_DB=agrisentinel
DATABASE_URL=postgresql://agrisentinel:agrisentinel@postgis:5432/agrisentinel

# ── MinIO (S3-compatible object store / raw lake) ──
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=agrisentinel
S3_SECRET_KEY=agrisentinel
S3_BUCKET=agrisentinel
S3_REGION=us-east-1

# ── Kafka / Redpanda (Kafka API-compatible event stream) ──
# The shipped compose uses Apache Kafka (KRaft); inside it the host is `kafka`.
# Running scripts from your host instead? Use localhost:9092.
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_DETECTIONS=agrisentinel.detections

# ── Pipeline knobs ──
AOI_CONFIG=config/aoi_changhua.yaml
# DATA_DIR defaults to ./data (gitignored) when unset — never an absolute path.
# DATA_DIR=./data

# Change detector: "spectral" (numpy NDBI/NDVI, default, no GPU) or "torchgeo"
# (requires the `ml` extra). The interface is swappable.
CHANGE_DETECTOR=spectral

# Embedder for the regulation RAG: "tfidf-svd" (sklearn, default, light) or
# "sentence-transformers" (requires the `ml` extra, better multilingual recall).
EMBEDDER=tfidf-svd
EMBED_DIM=384

# Microsoft Planetary Computer works without a key for moderate use. Supplying a
# subscription key raises rate limits (optional).
# PC_SUBSCRIPTION_KEY=

# Set to 1 to allow scripts to fall back to bundled sample data when an upstream
# source is unreachable (keeps the demo runnable offline). 0 = fail loudly.
ALLOW_OFFLINE_FALLBACK=1

LOG_LEVEL=INFO
